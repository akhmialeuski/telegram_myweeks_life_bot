#: dynamic key: help.text
msgctxt "help.text"
msgid "🤖 LifeWeeksBot - Helps you track the weeks of your life\n\n📋 Available commands:\n• /start - Registration and settings\n• /weeks - Show life weeks\n• /visualize - Visualize life weeks\n• /settings - Settings\n• /subscription - Subscription\n• /help - This help\n\n💡 Fun facts:\n• There are 52 weeks in a year\n• Average life expectancy: 80 years\n• That's about 4,160 weeks\n\n🎯 The goal of the bot is to help you realize the value of time!"
msgstr "🤖 LifeWeeksBot - Helps you track the weeks of your life\n\n📋 Available commands:\n• /start - Registration and settings\n• /weeks - Show life weeks\n• /visualize - Visualize life weeks\n• /settings - Settings\n• /subscription - Subscription\n• /help - This help\n\n💡 Fun facts:\n• There are 52 weeks in a year\n• Average life expectancy: 80 years\n• That's about 4,160 weeks\n\n🎯 The goal of the bot is to help you realize the value of time!"

#: dynamic key: start.welcome_existing
msgctxt "start.welcome_existing"
msgid "👋 Hello, %(first_name)s! Welcome back to LifeWeeksBot!\n\nYou are already registered and ready to track your life weeks.\n\nUse /weeks to view your life weeks.\nUse /help for help."
msgstr "👋 Hello, %(first_name)s! Welcome back to LifeWeeksBot!\n\nYou are already registered and ready to track your life weeks.\n\nUse /weeks to view your life weeks.\nUse /help for help."

#: dynamic key: start.welcome_new
msgctxt "start.welcome_new"
msgid "👋 Hello, %(first_name)s! Welcome to LifeWeeksBot!\n\nThis bot will help you track the weeks of your life.\n\n📅 Please enter your birth date in DD.MM.YYYY format\nFor example: 15.03.1990"
msgstr "👋 Hello, %(first_name)s! Welcome to LifeWeeksBot!\n\nThis bot will help you track the weeks of your life.\n\n📅 Please enter your birth date in DD.MM.YYYY format\nFor example: 15.03.1990"

#: dynamic key: registration.success
msgctxt "registration.success"
msgid "✅ Great! You have successfully registered!\n\n📅 Birth date: %(birth_date)s\n🎂 Age: %(age)s years\n📊 Weeks lived: %(weeks_lived)s\n⏳ Remaining weeks: %(remaining_weeks)s\n📈 Life progress: %(life_percentage)s\n\nNow you can use commands:\n• /weeks - show life weeks\n• /visualize - visualize weeks\n• /help - help"
msgstr "✅ Great! You have successfully registered!\n\n📅 Birth date: %(birth_date)s\n🎂 Age: %(age)s years\n📊 Weeks lived: %(weeks_lived)s\n⏳ Remaining weeks: %(remaining_weeks)s\n📈 Life progress: %(life_percentage)s\n\nNow you can use commands:\n• /weeks - show life weeks\n• /visualize - visualize weeks\n• /help - help"

#: dynamic key: registration.error
msgctxt "registration.error"
msgid "❌ An error occurred during registration.\nTry again or contact the administrator."
msgstr "❌ An error occurred during registration.\nTry again or contact the administrator."

#: dynamic key: birth_date.future_error
msgctxt "birth_date.future_error"
msgid "❌ Birth date cannot be in the future!\nPlease enter a valid date in DD.MM.YYYY format"
msgstr "❌ Birth date cannot be in the future!\nPlease enter a valid date in DD.MM.YYYY format"

#: dynamic key: birth_date.old_error
msgctxt "birth_date.old_error"
msgid "❌ Birth date is too old!\nPlease enter a valid date in DD.MM.YYYY format"
msgstr "❌ Birth date is too old!\nPlease enter a valid date in DD.MM.YYYY format"

#: dynamic key: birth_date.format_error
msgctxt "birth_date.format_error"
msgid "❌ Invalid date format!\nPlease enter date in DD.MM.YYYY format\nFor example: 15.03.1990"
msgstr "❌ Invalid date format!\nPlease enter date in DD.MM.YYYY format\nFor example: 15.03.1990"

#: dynamic key: subscription.already_active
msgctxt "subscription.already_active"
